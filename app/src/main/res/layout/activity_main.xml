<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_cream">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_gradient_hero"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/space_16"
            android:paddingEnd="@dimen/space_16"
            android:paddingTop="@dimen/space_14"
            android:paddingBottom="@dimen/space_10">

            <!-- Top row: Welcome + icons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvWelcomeUser"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Halo, Admin! 👋"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        android:alpha="0.9" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MenuKita"
                        android:textAppearance="@style/TextAppearance.MenuKita.Display"
                        android:textColor="@color/white"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Masakan Lezat, Suasana Berkesan"
                        android:textColor="@color/white"
                        android:alpha="0.85"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvTotalMenu"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 Menu"
                        android:textColor="@color/white"
                        android:alpha="0.75"
                        android:textSize="11sp"
                        android:layout_marginEnd="@dimen/space_4" />

                    <ImageButton
                        android:id="@+id/btnStats"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="@dimen/space_6"
                        android:background="@drawable/bg_card_glass"
                        android:contentDescription="Lihat statistik"
                        android:src="@android:drawable/ic_menu_info_details"
                        android:tint="@color/primary_orange" />

                    <ImageButton
                        android:id="@+id/btnSort"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="@dimen/space_6"
                        android:background="@drawable/bg_card_glass"
                        android:contentDescription="Urutkan menu"
                        android:src="@android:drawable/ic_menu_sort_by_size"
                        android:tint="@color/primary_orange" />

                    <ImageButton
                        android:id="@+id/btnOrders"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="@dimen/space_6"
                        android:background="@drawable/bg_card_glass"
                        android:contentDescription="Pesanan"
                        android:src="@drawable/ic_orders_receipt_24"
                        android:tint="@color/primary_orange" />

                    <ImageButton
                        android:id="@+id/btnProfile"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="@dimen/space_6"
                        android:background="@drawable/bg_card_glass"
                        android:contentDescription="Profil"
                        android:src="@drawable/ic_profile_24"
                        android:tint="@color/primary_orange" />
                </LinearLayout>
            </LinearLayout>

            <!-- Statistics Card (Initially Hidden) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStats"
                style="@style/Widget.MenuKita.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_12"
                android:visibility="gone"
                app:cardBackgroundColor="@color/primary_orange_dark">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/space_12">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Paling Murah"
                            android:textColor="@color/white"
                            android:alpha="0.7"
                            android:textSize="10sp" />
                        <TextView
                            android:id="@+id/tvMinPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rp 0"
                            android:textColor="@color/gold_accent"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center_vertical"
                        android:layout_marginHorizontal="@dimen/space_12"
                        android:background="@color/white"
                        android:alpha="0.2" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Paling Mahal"
                            android:textColor="@color/white"
                            android:alpha="0.7"
                            android:textSize="10sp" />
                        <TextView
                            android:id="@+id/tvMaxPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rp 0"
                            android:textColor="@color/orange_accent"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Search Bar + Filter -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_16"
                android:orientation="horizontal">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilSearch"
                    style="@style/Widget.MenuKita.TextInputLayout.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:startIconDrawable="@android:drawable/ic_menu_search"
                    app:startIconTint="@color/primary_orange"
                    app:hintEnabled="true"
                    android:hint="Cari menu...">

                    <AutoCompleteTextView
                        android:id="@+id/etSearch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:singleLine="true" />
                </com.google.android.material.textfield.TextInputLayout>

                <ImageButton
                    android:id="@+id/btnFilter"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="@dimen/space_8"
                    android:background="@drawable/bg_card_glass"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Filter"
                    android:src="@drawable/ic_filter_24"
                    android:tint="@color/primary_orange" />
            </LinearLayout>

            <!-- Promo Banner Carousel -->
            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/vpBanner"
                android:layout_width="match_parent"
                android:layout_height="170dp"
                android:layout_marginTop="@dimen/space_12"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingBottom="@dimen/space_4" />

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabBanner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/space_6"
                android:background="@android:color/transparent"
                app:tabBackground="@drawable/dot_indicator"
                app:tabGravity="center"
                app:tabIndicatorHeight="0dp"
                app:tabMaxWidth="35dp"
                app:tabMinWidth="35dp"
                app:tabMode="fixed"
                app:tabPaddingEnd="-12dp"
                app:tabPaddingStart="-12dp"
                app:tabRippleColor="@android:color/transparent" />
        </LinearLayout>

        <!-- Kategori Chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="@dimen/space_12"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupKategori"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="@dimen/space_16"
                android:paddingEnd="@dimen/space_16"
                app:selectionRequired="true"
                app:singleLine="true"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSemua"
                    style="@style/Widget.MenuKita.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="Semua"
                    app:chipBackgroundColor="@color/chip_bg"
                    app:chipStrokeColor="@color/primary_orange"
                    android:textColor="@color/chip_text" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipMakanan"
                    style="@style/Widget.MenuKita.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Makanan"
                    app:chipBackgroundColor="@color/chip_bg"
                    app:chipStrokeColor="@color/primary_orange"
                    android:textColor="@color/chip_text" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipMinuman"
                    style="@style/Widget.MenuKita.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Minuman"
                    app:chipBackgroundColor="@color/chip_bg"
                    app:chipStrokeColor="@color/primary_orange"
                    android:textColor="@color/chip_text" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipDessert"
                    style="@style/Widget.MenuKita.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dessert"
                    app:chipBackgroundColor="@color/chip_bg"
                    app:chipStrokeColor="@color/primary_orange"
                    android:textColor="@color/chip_text" />
            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>
    </com.google.android.material.appbar.AppBarLayout>

    <com.example.menukita.ui.AmbientParticlesView
        android:id="@+id/ambientParticles"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:clickable="false"
        android:focusable="false" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background_cream"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipeRefresh"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMenu"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingTop="@dimen/space_12"
                android:layoutAnimation="@anim/layout_fade_in"
                tools:listitem="@layout/item_menu" />
        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

        <include
            layout="@layout/skeleton_menu_list"
            android:visibility="visible"
            android:id="@+id/skeletonInclude" />

        <TextView
            android:id="@+id/tvEmptyState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Menu tidak ditemukan :("
            android:textColor="@color/gray_text"
            android:textSize="16sp"
            android:visibility="gone" />

        <com.example.menukita.ui.ParticleBurstView
            android:id="@+id/particleBurst"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="false"
            android:focusable="false" />
    </FrameLayout>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabAdd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="@dimen/space_24"
        android:icon="@android:drawable/ic_input_add"
        android:contentDescription="Aksi cepat"
        android:text="Tambah"
        android:stateListAnimator="@animator/press_scale"
        app:backgroundTint="@color/accent_green"
        app:iconTint="@color/white"
        app:rippleColor="@color/ripple_orange"
        app:layout_dodgeInsetEdges="bottom" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabQuickOrders"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="@dimen/space_24"
        android:layout_marginBottom="96dp"
        android:contentDescription="Buka pesanan"
        android:src="@android:drawable/ic_menu_agenda"
        android:visibility="gone"
        app:backgroundTint="@color/primary_orange"
        app:tint="@color/white"
        app:layout_dodgeInsetEdges="bottom" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabQuickAdd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="@dimen/space_24"
        android:layout_marginBottom="152dp"
        android:contentDescription="Tambah menu"
        android:src="@android:drawable/ic_input_add"
        android:visibility="gone"
        app:backgroundTint="@color/accent_green"
        app:tint="@color/white"
        app:layout_dodgeInsetEdges="bottom" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>

<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.MenuKita.Card"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginHorizontal="@dimen/space_4"
    android:layout_marginTop="@dimen/space_8"
    android:foreground="?attr/selectableItemBackground"
    android:stateListAnimator="@animator/press_scale"
    app:cardBackgroundColor="@android:color/transparent">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_gradient_warm">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/space_16">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_badge_kategori"
                    android:paddingHorizontal="@dimen/space_8"
                    android:paddingVertical="@dimen/space_2"
                    android:text="Hot"
                    android:textColor="@color/primary_orange"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:animation="@anim/pulse" />

                <TextView
                    android:id="@+id/tvBannerTag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Promo"
                    android:textAppearance="@style/TextAppearance.MenuKita.Label"
                    android:textColor="@color/white"
                    android:alpha="0.9" />

                <TextView
                    android:id="@+id/tvBannerTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_4"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="Diskon Spesial"
                    android:textAppearance="@style/TextAppearance.MenuKita.Title"
                    android:textColor="@color/white"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvBannerSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_4"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="Untuk menu pilihan hari ini"
                    android:textAppearance="@style/TextAppearance.MenuKita.Body"
                    android:textColor="@color/white"
                    android:alpha="0.88"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_6"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvBannerPriceNow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp 0"
                        android:textColor="@color/white"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvBannerPriceOld"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_8"
                        android:text="Rp 0"
                        android:textColor="@color/white"
                        android:alpha="0.75"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvBannerHighlights"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_6"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="Diskon · Gratis Ongkir · Promo"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <ImageView
                android:id="@+id/ivBanner"
                android:layout_width="86dp"
                android:layout_height="86dp"
                android:background="@drawable/bg_card_glass"
                android:contentDescription="Ilustrasi promo"
                android:padding="@dimen/space_8"
                android:scaleType="centerCrop"
                android:src="@drawable/placeholder_food" />
        </LinearLayout>

        <View
            android:id="@+id/viewShimmer"
            android:layout_width="72dp"
            android:layout_height="match_parent"
            android:alpha="0.55"
            android:background="@drawable/bg_shimmer_strip"
            android:translationX="-120dp" />
    </FrameLayout>
</com.google.android.material.card.MaterialCardView>

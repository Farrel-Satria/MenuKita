<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/space_16">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Filter Menu"
        android:textStyle="bold"
        android:textColor="@color/neutral_dark" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_12"
        android:text="Urutkan"
        android:textColor="@color/gray_text" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipSortGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_8"
        app:singleSelection="true"
        app:selectionRequired="true">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipSortAZ"
            style="@style/Widget.MenuKita.Chip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="A-Z"
            android:checked="true" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipSortLow"
            style="@style/Widget.MenuKita.Chip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Harga Terendah" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipSortHigh"
            style="@style/Widget.MenuKita.Chip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Harga Tertinggi" />
    </com.google.android.material.chip.ChipGroup>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_12"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rentang Harga"
            android:textColor="@color/gray_text" />

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tvPriceRangeValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rp 0 - Rp 200rb"
            android:textColor="@color/primary_orange"
            android:textStyle="bold"
            android:textSize="13sp" />
    </LinearLayout>

    <com.google.android.material.slider.RangeSlider
        android:id="@+id/priceRange"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_4"
        android:valueFrom="0"
        android:valueTo="200000"
        app:values="@array/default_price_range"
        app:trackColorActive="@color/primary_orange"
        app:thumbColor="@color/primary_orange"
        app:haloColor="#22FB8C00" />

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switchFavoriteOnly"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_8"
        android:text="Hanya Favorit" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_12"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReset"
            style="@style/Widget.MenuKita.Button.Outlined"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Reset" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnApply"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_12"
            android:layout_weight="1"
            android:text="Terapkan"
            app:backgroundTint="@color/accent_green" />
    </LinearLayout>
</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_hero_anim">

    <ImageView
        android:id="@+id/ivSplashLogo"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:contentDescription="Logo"
        android:src="@drawable/ic_launcher_foreground"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvSplashTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvSplashTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MenuKita"
        android:textAppearance="@style/TextAppearance.MenuKita.Display"
        android:textColor="@color/white"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/ivSplashLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvSplashTagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_8"
        android:text="Hangatkan harimu dengan menu terbaik."
        android:textColor="@color/white"
        android:alpha="0.85"
        app:layout_constraintTop_toBottomOf="@id/tvSplashTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottieLoading"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="@dimen/space_24"
        app:lottie_rawRes="@raw/splash_loading"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        app:layout_constraintTop_toBottomOf="@id/tvSplashTagline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/splashProgress"
        android:layout_width="160dp"
        android:layout_height="6dp"
        android:layout_marginTop="@dimen/space_12"
        app:trackThickness="6dp"
        app:indicatorColor="@color/white"
        app:trackColor="@color/splash_progress_track"
        app:layout_constraintTop_toBottomOf="@id/lottieLoading"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <include
        android:id="@+id/waveLoading"
        layout="@layout/loading_wave"
        android:layout_marginTop="@dimen/space_12"
        app:layout_constraintTop_toBottomOf="@id/splashProgress"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
